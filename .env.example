# Pact Network — Backend Environment
# Copy to packages/backend/.env

# PostgreSQL connection (matches docker-compose.dev.yml defaults)
DATABASE_URL=postgresql://pact:pact@localhost:5433/pact

# Backend server port
PORT=3001

# Admin dashboard token (for /api/v1/admin/* endpoints)
ADMIN_TOKEN=pact-admin-local

# Note: API keys are NOT stored in env.
# Generate one with: pnpm run generate-key <label>
# Keys are hashed and stored in the database.
