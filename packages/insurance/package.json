{
  "name": "@pact-network/insurance",
  "version": "1.0.0",
  "description": "TypeScript SDK for Pact Network's on-chain parametric insurance program on Solana — enable insurance, top up delegations, submit claims, and query pool state.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "idl",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pact-network",
    "solana",
    "anchor",
    "insurance",
    "parametric",
    "x402",
    "agent"
  ],
  "homepage": "https://pactnetwork.io",
  "bugs": {
    "url": "https://pactnetwork.io"
  },
  "license": "MIT",
  "author": "Pact Network",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/*.test.ts",
    "codama:generate": "node ./scripts/codama-generate.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anchor-lang/core": "^1.0.0",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.0.0",
    "@codama/renderers-js": "^2.2.0",
    "@solana/kit": "^6.8.0",
    "@types/bn.js": "^5.1.5",
    "@types/node": "^22.0.0",
    "codama": "^1.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
