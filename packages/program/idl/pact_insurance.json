        {
          "name": "config",
          "isMut": false,
          "isSigner": false,
          "docs": ["Protocol config PDA — seeds = [\"protocol\"]. Read-only."]
        },
        {
          "name": "pool",
          "isMut": true,
          "isSigner": false,
          "docs": ["Coverage pool PDA — seeds = [\"pool\", providerHostname]."]
        },
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false,
          "docs": ["SPL-Token vault PDA — seeds = [\"vault\", pool]. Destination of the transfer."]
        },
        {
          "name": "position",
          "isMut": true,
          "isSigner": false,
          "docs": ["Underwriter position PDA — seeds = [\"position\", pool, underwriter]. init_if_needed; handler branches on is_data_empty."]
        },
        {
          "name": "underwriterTokenAccount",
          "isMut": true,
          "isSigner": false,
          "docs": ["SPL-Token account source of the transfer. mint must equal pool.usdcMint; owner must equal underwriter."]
        },
        {
          "name": "underwriter",
          "isMut": true,
          "isSigner": true,
          "docs": ["Underwriter wallet. Signs the transfer and pays rent for position init."]
        },
        {
          "name": "tokenProgram",
          "isMut": false,
          "isSigner": false,
          "docs": ["SPL Token Program — `TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA`."]
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false,
          "docs": ["System Program — `11111111111111111111111111111111`."]
        }
