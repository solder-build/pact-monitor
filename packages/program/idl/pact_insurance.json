{
  "version": "0.1.0",
  "name": "pact_insurance",
  "instructions": [
    {
      "name": "initializeProtocol",
      "accounts": [
        {
          "name": "config",
          "isMut": true,
          "isSigner": false,
          "docs": [
            "Protocol config PDA derived from seeds = [\"protocol\"]. Created by this instruction."
          ]
        },
        {
          "name": "deployer",
          "isMut": true,
          "isSigner": true,
          "docs": ["Fee payer that funds the PDA creation. Signs the transaction."]
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false,
          "docs": ["System Program — `11111111111111111111111111111111`."]
        }
      ],
      "args": [
        {
          "name": "args",
          "type": {
            "defined": "InitializeProtocolArgs"
          }
        }
      ],
      "discriminant": {
        "type": "u8",
        "value": 0
      }
    },
    {
      "name": "updateConfig",
      "accounts": [
        {
          "name": "config",
          "isMut": true,
          "isSigner": false,
          "docs": [
            "Protocol config PDA — seeds = [\"protocol\"]. Loaded and mutated in place."
          ]
        },
        {
          "name": "authority",
          "isMut": false,
          "isSigner": true,
          "docs": ["Must match `config.authority` (has_one in Anchor source)."]
        }
      ],
      "args": [
        {
          "name": "args",
          "type": {
            "defined": "UpdateConfigArgs"
          }
        }
      ],
      "discriminant": {
        "type": "u8",
        "value": 1
      }
    },
    {
      "name": "updateOracle",
      "accounts": [
        {
          "name": "config",
          "isMut": true,
          "isSigner": false,
          "docs": [
            "Protocol config PDA — seeds = [\"protocol\"]. Loaded and mutated in place."
          ]
        },
        {
          "name": "authority",
          "isMut": false,
          "isSigner": true,
          "docs": ["Must match `config.authority` (has_one in Anchor source)."]
        }
      ],
      "args": [
        {
          "name": "newOracle",
          "type": "publicKey"
        }
      ],
      "discriminant": {
        "type": "u8",
        "value": 2
      }
    },
    {
      "name": "createPool",
      "accounts": [
        {
          "name": "config",
          "isMut": false,
          "isSigner": false,
          "docs": ["Protocol config PDA — seeds = [\"protocol\"]. Read-only."]
        },
        {
          "name": "pool",
          "isMut": true,
          "isSigner": false,
          "docs": ["Coverage pool PDA — seeds = [\"pool\", providerHostname]. Created by this instruction."]
        },
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false,
          "docs": ["SPL-Token vault PDA — seeds = [\"vault\", pool]. Created owned by the Token Program; authority = pool."]
        },
        {
          "name": "poolUsdcMint",
          "isMut": false,
          "isSigner": false,
          "docs": ["USDC mint. Handler enforces equality with `config.usdcMint` (Unauthorized 6018 otherwise)."]
        },
        {
          "name": "authority",
          "isMut": true,
          "isSigner": true,
          "docs": ["Protocol authority; must match `config.authority`. Pays rent."]
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false,
          "docs": ["System Program — `11111111111111111111111111111111`."]
        },
        {
          "name": "tokenProgram",
          "isMut": false,
          "isSigner": false,
          "docs": ["SPL Token Program — `TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA`."]
        },
        {
          "name": "rent",
          "isMut": false,
          "isSigner": false,
          "docs": ["Rent sysvar. Kept for account-list compatibility with the Anchor builder; unused by the handler."]
        }
      ],
      "args": [
        {
          "name": "args",
          "type": {
            "defined": "CreatePoolArgs"
          }
        }
      ],
      "discriminant": {
        "type": "u8",
        "value": 3
      }
    },
    {
      "name": "deposit",
