          "name": "pool",
          "isMut": true,
          "isSigner": false,
          "docs": ["Coverage pool PDA — seeds = [\"pool\", providerHostname]. Mutated in place (insuranceRateBps, updatedAt)."]
        },
        {
          "name": "oracleSigner",
          "isMut": false,
          "isSigner": true,
          "docs": ["Must match `config.oracle`. Handler rejects with UnauthorizedOracle (6025) otherwise. Dedicated oracle crank signer — admin authority stays cold."]
        }
      ],
      "args": [
        {
          "name": "newRateBps",
          "type": "u16"
        }
      ],
      "discriminant": {
        "type": "u8",
        "value": 9
      }
    },
    {
      "name": "enableInsurance",
      "accounts": [
        {
          "name": "config",
          "isMut": false,
          "isSigner": false,
          "docs": ["Protocol config PDA — seeds = [\"protocol\"]. Read-only."]
        },
        {
          "name": "pool",
          "isMut": true,
          "isSigner": false,
          "docs": ["Coverage pool PDA — seeds = [\"pool\", providerHostname]. Writable (active_policies, updated_at)."]
        },
        {
          "name": "policy",
          "isMut": true,
          "isSigner": false,
          "docs": ["Policy PDA — seeds = [\"policy\", pool, agent (wallet)]. Created by this instruction."]
        },
        {
          "name": "agentTokenAccount",
          "isMut": false,
          "isSigner": false,
          "docs": ["SPL-Token account. mint == config.usdcMint; owner == agent; delegate == pool; delegated_amount > 0."]
        },
        {
          "name": "agent",
          "isMut": true,
          "isSigner": true,
          "docs": ["Agent wallet. Tx signer; pays policy PDA rent. Spec §3.6 seed rule: WALLET pubkey, not agent_token_account."]
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false,
          "docs": ["System Program — `11111111111111111111111111111111`."]
        }
      ],
      "args": [
        {
          "name": "args",
          "type": {
            "defined": "EnableInsuranceArgs"
          }
        }
      ],
      "discriminant": {
        "type": "u8",
        "value": 5
      }
    },
    {
      "name": "withdraw",
      "accounts": [
        {
          "name": "config",
          "isMut": false,
          "isSigner": false,
          "docs": ["Protocol config PDA — seeds = [\"protocol\"]. Read-only."]
        },
        {
          "name": "pool",
          "isMut": true,
          "isSigner": false,
          "docs": ["Coverage pool PDA — seeds = [\"pool\", providerHostname]. Signer of the token Transfer via pool_signer_seeds."]
        },
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false,
          "docs": ["SPL-Token vault PDA — seeds = [\"vault\", pool]. Source of the transfer; authority = pool."]
        },
        {
          "name": "position",
          "isMut": true,
          "isSigner": false,
          "docs": ["Underwriter position PDA — seeds = [\"position\", pool, underwriter]. Cooldown gate reads position.depositTimestamp."]
        },
        {
          "name": "underwriterTokenAccount",
          "isMut": true,
          "isSigner": false,
          "docs": ["SPL-Token account destination of the transfer. mint must equal pool.usdcMint; owner must equal underwriter."]
        },
        {
          "name": "underwriter",
          "isMut": false,
          "isSigner": true,
          "docs": ["Underwriter wallet. Tx signer; does NOT sign the Transfer CPI — the pool PDA signs via invoke_signed."]
        },
        {
          "name": "tokenProgram",
          "isMut": false,
          "isSigner": false,
          "docs": ["SPL Token Program — `TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA`."]
        },
        {
          "name": "clock",
          "isMut": false,
          "isSigner": false,
          "docs": ["Clock sysvar — `SysvarC1ock11111111111111111111111111111111`. Handler reads via `Clock::get()`; kept in account list for wire parity."]
        }
      ],
      "args": [
        {
          "name": "amount",
          "type": "u64"
        }
      ],
      "discriminant": {
        "type": "u8",
        "value": 8
      }
    }
