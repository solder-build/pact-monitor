# Pact Network Backend — environment template
#
# Copy to packages/backend/.env for local dev. Loaded via `dotenv/config` at
# startup (see src/index.ts). Cloud Run injects these via --env-vars-file in
# the deploy workflow; see .github/workflows/deploy.yaml.
#
# Format note: this file is dotenv (KEY=value). The ENV_STG / ENV_PROD GitHub
# secrets used by the deploy workflow must be YAML (KEY: value), not dotenv,
# because gcloud run deploy --env-vars-file requires YAML.

# ─── HTTP ──────────────────────────────────────────────────────────────────
# Local dev only. Cloud Run injects PORT — leave it unset in ENV_STG/ENV_PROD.
PORT=3001

# Comma-separated CORS allowlist for cross-origin scorecard requests. No
# trailing slashes. Add the Vercel deployment origin after the scorecard is
# live (e.g. https://pact-scorecard.vercel.app).
CORS_ORIGINS=http://localhost:5173

# ─── Database ──────────────────────────────────────────────────────────────
# Local dev uses docker-compose.dev.yml on port 5433. In staging/prod, point
# at the managed instance (Cloud SQL / Neon / Supabase). If the password
# contains special characters (@, :, /, ?, #, %), URL-encode them.
DATABASE_URL=postgresql://pact:pact@localhost:5433/pact

# ─── Solana / on-chain ────────────────────────────────────────────────────
# RPC endpoint. Defaults to http://127.0.0.1:8899 (solana-test-validator).
# Staging uses https://api.devnet.solana.com; prefer a paid RPC (Helius,
# QuickNode, Triton) for anything beyond smoke tests.
SOLANA_RPC_URL=http://127.0.0.1:8899

# Deployed Pact Insurance program ID. Must match Anchor.toml for the target
# cluster. Current Pinocchio devnet ID (post-WP-19, 2026-04-24):
#   7i9zJMwaTRw4Tdy7SAfXJdDkYQD39xyKmkBhWuUSgDJU
# Legacy Anchor devnet ID kept as rollback fallback only:
#   2Go74eCvY8vCco3WPuteGzrhKz8v3R7Pcp5tjuFpcmN3
SOLANA_PROGRAM_ID=7i9zJMwaTRw4Tdy7SAfXJdDkYQD39xyKmkBhWuUSgDJU

# USDC mint used by the protocol. config.usdc_mint is frozen post-init (H-03),
# so this must match what was passed to initialize/init-devnet.ts.
#   - Devnet (Phantom-controlled test mint): 5vcEdU8fBksfRH42wrebUV6dNEENPbdaBtAmw79ZNuSE
#   - Mainnet (Circle USDC):                 EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_MINT=5vcEdU8fBksfRH42wrebUV6dNEENPbdaBtAmw79ZNuSE

# Oracle signer for settle_premium, update_rates, and submit_claim. Set EXACTLY
# ONE of the following — base58 is preferred for managed envs (Cloud Run,
# Secret Manager), file path for local dev.
#
#   ORACLE_KEYPAIR_BASE58 — bs58-encoded 64-byte secret key, single string
#   ORACLE_KEYPAIR_PATH   — absolute or ~/path to a Solana JSON keypair file
#
# Generate the base58 form with:
#   node packages/program/scripts/export-keypair-base58.mjs \
#     packages/backend/.secrets/oracle-keypair.json
ORACLE_KEYPAIR_PATH=./.secrets/oracle-keypair.json
# ORACLE_KEYPAIR_BASE58=

# Faucet signer for /api/v1/faucet/drip. Must hold SPL mint authority on
# USDC_MINT above — devnet only. The faucet is hard-gated off on mainnet by a
# genesis-hash check, so setting this on mainnet is a no-op (the route returns
# 410 Gone regardless). If unset, the /faucet endpoints report enabled:false.
#
#   FAUCET_KEYPAIR_BASE58 — bs58-encoded 64-byte secret key, single string
#   FAUCET_KEYPAIR_PATH   — absolute or ~/path to a Solana JSON keypair file
#
# Hackathon shortcut: we reuse the Phantom deployer keypair that currently
# holds mint authority on the devnet test USDC mint. Export to base58 with:
#   node packages/program/scripts/export-keypair-base58.mjs \
#     ~/.config/solana/phantom-devnet.json
FAUCET_KEYPAIR_PATH=~/.config/solana/phantom-devnet.json
# FAUCET_KEYPAIR_BASE58=

# ─── Cranks ────────────────────────────────────────────────────────────────
# Gate for the premium-settler and rate-updater loops. Must be the literal
# string "true" to enable — any other value leaves the cranks off. Off by
# default so test environments don't accidentally post transactions.
CRANK_ENABLED=false

# Interval between crank ticks in milliseconds. Defaults to 900000 (15 min).
# CRANK_INTERVAL_MS=900000

# ─── Admin API ─────────────────────────────────────────────────────────────
# Bearer token guarding /api/v1/admin/* (overview, backend-health, costs, key
# provisioning, etc.). Generate with: openssl rand -hex 32. If unset, all
# admin routes return 503 "Admin not configured".
ADMIN_TOKEN=

# ─── Notes ─────────────────────────────────────────────────────────────────
# API keys are NOT stored in env. Generate with:
#   pnpm --filter @pact-network/backend run generate-key <label> --agent-pubkey <pk>
# Keys are hashed and stored in the api_keys table.
