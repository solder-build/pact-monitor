# Pact Network Backend — environment template
# Copy to packages/backend/.env for local dev. Cloud Run injects these directly.

# Postgres connection string. Local dev uses docker-compose.dev.yml on port 5433.
# In staging/prod, point at the managed instance (Cloud SQL, Neon, etc.).
DATABASE_URL=postgresql://pact:pact@localhost:5433/pact

# HTTP port. Cloud Run injects PORT automatically — leave unset there.
PORT=3001

# Comma-separated CORS allowlist for cross-origin scorecard requests.
# Production should list the public scorecard origin(s).
CORS_ORIGINS=https://pactnetwork.io,http://localhost:5173

# Note: API keys are NOT stored in env. Generate with: pnpm run generate-key <label>
# Keys are hashed and stored in the api_keys table.
